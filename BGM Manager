using UnityEngine;
using UnityEngine.SceneManagement;

public class BGMPlayer : MonoBehaviour
{
    private AudioSource audioSource;

    [Header("BGMリスト")]
    public AudioClip titleBGM;
    public AudioClip stage1BGM;
    public AudioClip stage2BGM;
    public AudioClip stage3BGM;

    private void Awake()
    {
        // 既に存在する場合は破棄（重複防止）
        var objs = FindObjectsOfType<BGMPlayer>();
        if (objs.Length > 1)
        {
            Destroy(gameObject);
            return;
        }

        DontDestroyOnLoad(gameObject);
        audioSource = GetComponent<AudioSource>();

        // シーンがロードされたらイベント呼び出し
        SceneManager.sceneLoaded += OnSceneLoaded;
    }

    private void OnDestroy()
    {
        // イベント解除（メモリリーク防止）
        SceneManager.sceneLoaded -= OnSceneLoaded;
    }

    private void OnSceneLoaded(Scene scene, LoadSceneMode mode)
    {
        // シーン名でBGMを切り替え
        switch (scene.name)
        {
            case "Top":
                PlayBGM(titleBGM);
                break;

            case "CourseSelection":
                PlayBGM(titleBGM);
                break;

            case "Game_course1":
            case "Game_course1-H":
            case "Game_course2":
            case "Game_course2-H":
                PlayBGM(stage1BGM);
                break;

            case "Game_course3":
            case "Game_course3-H":
            case "Game_course4":
            case "Game_course4-H":
                PlayBGM(stage2BGM);
                break;

            case "Game_course5":
            case "Game_course5-H":
            case "Game_course6":
            case "Game_course6-H":
            case "Game_course7":
            case "Game_course7-H":
            case "Game_course8":
            case "Game_course8-H":
                PlayBGM(stage3BGM);
                break;
        }
    }

    public void PlayBGM(AudioClip clip)
    {
        if (clip == null) return;
        if (audioSource.clip == clip) return; // 同じ曲なら再生し直さない

        audioSource.clip = clip;
        audioSource.loop = true;
        audioSource.Play();
    }
}
